// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String  @id @default(cuid())
  clerkId String  @unique
  email   String  @unique
  name    String?
  boards        Board[]
  comments      Comment[]
  boardMembers  BoardMember[]
  taskAssignees TaskAssignee[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String  @id @default(cuid())
  type    String  // "assigned" | "comment"
  message String
  read    Boolean @default(false)

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  boardId String?
  taskId  String?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId])
}

model Board {
  id          String  @id @default(cuid())
  title       String
  description String?
  color       String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  list         List[]
  labels       Label[]
  members      BoardMember[]
  invitations  Invitation[]
  activityLogs ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BoardMember {
  id   String @id @default(cuid())
  role String @default("member")

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([boardId, userId])
  @@index([boardId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  status    String   @default("pending")
  expiresAt DateTime

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([boardId])
  @@index([token])
}

model List {
  id    String @id @default(cuid())
  title String
  order Int

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?
  completed   Boolean   @default(false)
  priority    String?
  startDate   DateTime?
  dueDate     DateTime?

  order Int

  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  labels      TaskLabel[]
  comments    Comment[]
  attachments Attachment[]
  assignees   TaskAssignee[]
  subtasks    Subtask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listId])
}

model TaskAssignee {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([taskId])
}

model Comment {
  id      String @id @default(cuid())
  content String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model Label {
  id      String @id @default(cuid())
  title   String
  color   String

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks TaskLabel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  order     Int

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
}

model Attachment {
  id       String @id @default(cuid())
  filename String
  url      String
  size     Int

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
}

model ActivityLog {
  id      String @id @default(cuid())
  type    String
  message String

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([boardId, createdAt])
}
